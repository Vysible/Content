generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(STAFF)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiKeys  ApiKey[]
  projects Project[]
}

model ApiKey {
  id           String    @id @default(cuid())
  name         String
  provider     Provider
  encryptedKey String
  model        String?
  active       Boolean   @default(true)
  expiresAt    DateTime? // Slice 26: Token-Ablauf-Warnsystem
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  @@index([provider, active])
}

model Project {
  id                  String        @id @default(cuid())
  name                String
  praxisUrl           String
  praxisName          String?
  fachgebiet          String?       // ZAHNARZT, KFO, GYNAEKOLOGE, ...
  planningStart       DateTime
  planningEnd         DateTime
  channels            String[]      // ["BLOG","NEWSLETTER","SOCIAL_INSTAGRAM",...]
  positioningDocument String?       // Markdown, max. ~4.000 Tokens
  themenPool          String?
  keywords            String[]
  canvaFolderId       String?
  wpUrl               String?       // Slice 22: WordPress-URL
  ktListId            String?       // Slice 23: Klick-Tipp Listen-ID
  scrapedData         Json?         // ScrapeResult-Snapshot
  themeResults        Json?         // ThemenItem[] – Slice 12
  textResults         Json?         // TextResult[] – Slice 13
  status              ProjectStatus @default(DRAFT)
  shareLinks          ShareLink[]
  praxisUsers         PraxisUser[]  // Slice 21
  comments            Comment[]     // Slice 21
  costReports         CostReport[]  // Slice 24
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  createdById String
  createdBy   User        @relation(fields: [createdById], references: [id])
  costEntries CostEntry[]

  @@index([status])
  @@index([createdById])
}

model CostEntry {
  id           String   @id @default(cuid())
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  timestamp    DateTime @default(now())
  model        String
  inputTokens  Int
  outputTokens Int
  costEur      Float
  step         String

  @@index([projectId])
  @@index([timestamp])
}

model ShareLink {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  token        String   @unique @default(cuid())
  passwordHash String
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([token])
  @@index([projectId])
}

// Slice 21 – Praxis-Portal
model PraxisUser {
  id            String    @id @default(cuid())
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  email         String
  name          String
  inviteToken   String    @unique @default(cuid())
  inviteExpires DateTime
  active        Boolean   @default(false) // wird true nach erstem Login
  createdAt     DateTime  @default(now())

  @@index([inviteToken])
  @@index([projectId])
}

model Comment {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contentIndex Int      // Index in textResults[]
  text         String
  authorName   String
  authorRole   String   @default("praxis") // "praxis" | "agentur"
  createdAt    DateTime @default(now())

  @@index([projectId, contentIndex])
}

// Slice 24 – KPI-Dashboard / Monatsreport
model CostReport {
  id        String   @id @default(cuid())
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  month     String   // YYYY-MM
  totalEur  Float
  breakdown Json     // { themes, blog, newsletter, social, chat, ... }
  pdfPath   String?
  createdAt DateTime @default(now())

  @@index([month])
  @@index([projectId])
}

enum Role {
  ADMIN
  STAFF
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum Provider {
  ANTHROPIC
  OPENAI
  DATASEO
  KLICKTIPP
  WORDPRESS
  HEDY
  CANVA
}
