generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(STAFF)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiKeys  ApiKey[]
  projects Project[]
}

model ApiKey {
  id           String   @id @default(cuid())
  name         String
  provider     Provider
  encryptedKey String
  model        String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  @@index([provider, active])
}

model Project {
  id                  String        @id @default(cuid())
  name                String
  praxisUrl           String
  praxisName          String?
  fachgebiet          String?       // ZAHNARZT, KFO, GYNAEKOLOGE, ...
  planningStart       DateTime
  planningEnd         DateTime
  channels            String[]      // ["BLOG","NEWSLETTER","SOCIAL_INSTAGRAM",...]
  positioningDocument String?       // Markdown, max. ~4.000 Tokens
  themenPool          String?
  keywords            String[]
  canvaFolderId       String?
  scrapedData         Json?         // ScrapeResult-Snapshot
  themeResults        Json?         // ThemenItem[] – Slice 12
  textResults         Json?         // TextResult[] – Slice 13
  status              ProjectStatus @default(DRAFT)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  createdById String
  createdBy   User        @relation(fields: [createdById], references: [id])
  costEntries CostEntry[]

  @@index([status])
  @@index([createdById])
}

model CostEntry {
  id           String   @id @default(cuid())
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  timestamp    DateTime @default(now())
  model        String
  inputTokens  Int
  outputTokens Int
  costEur      Float
  step         String

  @@index([projectId])
  @@index([timestamp])
}

enum Role {
  ADMIN
  STAFF
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum Provider {
  ANTHROPIC
  OPENAI
  DATASEO
  KLICKTIPP
  WORDPRESS
  HEDY
  CANVA
}
