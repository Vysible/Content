generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma/client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String?
  emailEncrypted    String?   // AES-256-GCM, Format: v1:iv:tag:cipher
  nameEncrypted     String?   // AES-256-GCM, Format: v1:iv:tag:cipher
  password          String
  role              Role      @default(STAFF)
  active            Boolean   @default(true)
  resetToken        String?
  resetTokenExpiry  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  apiKeys     ApiKey[]
  projects    Project[]
  canvaToken  CanvaToken?
}

model ApiKey {
  id           String    @id @default(cuid())
  name         String
  provider     Provider
  encryptedKey String
  model        String?
  active       Boolean   @default(true)
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  createdById  String
  createdBy    User      @relation(fields: [createdById], references: [id])
  projectsUsing Project[] @relation("ProjectApiKey")

  @@index([provider, active])
}

model Project {
  id                  String        @id @default(cuid())
  name                String
  praxisUrl           String
  praxisName          String?
  fachgebiet          String?
  planningStart       DateTime
  planningEnd         DateTime
  channels            String[]
  positioningDocument String?
  themenPool          String?
  keywords            String[]
  canvaFolderId       String?
  wpUrl               String?
  wpDraftPostId       String?
  ktListId            String?
  ktCampaignId        String?
  apiKeyId            String?
  apiKey              ApiKey?  @relation("ProjectApiKey", fields: [apiKeyId], references: [id], onDelete: SetNull)
  scrapedData         Json?
  themeResults        Json?
  textResults         Json?
  status              ProjectStatus @default(DRAFT)
  reviewMode          ReviewMode    @default(SIMPLE)
  hwgFlag             Boolean       @default(false)
  shareLinks          ShareLink[]
  praxisUsers         PraxisUser[]
  comments            Comment[]
  costReports         CostReport[]
  generationJobs      GenerationJob[]
  auditLogs           AuditLog[]
  invitationTokens    InvitationToken[]
  contentApprovals    ContentApproval[]
  clonedFrom          String?
  hedyImportHighlight Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  createdById String
  createdBy   User        @relation(fields: [createdById], references: [id])
  costEntries CostEntry[]

  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id])

  @@index([status])
  @@index([createdById])
  @@index([clientId])
}

model Client {
  id              String   @id @default(cuid())
  name            String   @unique
  canvaFolderId   String?
  canvaBrandKitId String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  projects Project[]

  @@index([name])
}

model GenerationJob {
  id             String              @id @default(cuid())
  projectId      String
  project        Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status         GenerationJobStatus @default(PENDING)
  completedSteps String[]
  events         Json                @default("[]")
  lastError      String?
  failedStep     String?
  queuePosition  Int?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([projectId])
  @@index([status])
}

model CanvaToken {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  encryptedAccessToken  String
  encryptedRefreshToken String
  expiresAt             DateTime
  scope                 String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model SmtpConfig {
  id                String   @id @default(cuid())
  host              String
  port              Int      @default(587)
  secure            Boolean  @default(false)
  user              String
  encryptedPassword String
  recipients        String[]
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model CostEntry {
  id           String   @id @default(cuid())
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  timestamp    DateTime @default(now())
  model        String
  inputTokens  Int
  outputTokens Int
  costEur      Float
  step         String

  @@index([projectId])
  @@index([timestamp])
}

model CostSettings {
  id              String   @id @default(cuid())
  monthlyAlertEur Float    @default(50.0)
  alertEnabled    Boolean  @default(true)
  updatedAt       DateTime @updatedAt
}

model AppConfig {
  id                   String   @id @default(cuid())
  // Themen-Qualitätsschwellwerte
  themesMinPraxisQuote Float    @default(0.8)
  themesMinSeoQuote    Float    @default(0.5)
  // KI-Modell pro Aufgabe
  modelThemes          String   @default("claude-sonnet-4-6")
  modelBlogOutline     String   @default("claude-sonnet-4-6")
  modelBlog            String   @default("claude-sonnet-4-6")
  modelNewsletter      String   @default("claude-sonnet-4-6")
  modelSocial          String   @default("claude-sonnet-4-6")
  modelImageBrief      String   @default("claude-sonnet-4-6")
  updatedAt            DateTime @updatedAt
}

model ShareLink {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  token        String   @unique @default(cuid())
  passwordHash String
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([token])
  @@index([projectId])
}

model PraxisUser {
  id             String    @id @default(cuid())
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  email          String
  name           String
  emailEncrypted String?   // AES-256-GCM, Format: v1:iv:tag:cipher
  nameEncrypted  String?   // AES-256-GCM, Format: v1:iv:tag:cipher
  // @deprecated — wird durch InvitationToken-Modell ersetzt (Drift-Fix P3-C)
  inviteToken    String    @unique @default(cuid())
  // @deprecated — wird durch InvitationToken.expiresAt ersetzt
  inviteExpires  DateTime
  active         Boolean   @default(false)
  createdAt      DateTime  @default(now())

  invitations      InvitationToken[]
  contentApprovals ContentApproval[]

  @@unique([email, projectId])
  @@index([inviteToken])
  @@index([projectId])
}

model InvitationToken {
  id           String    @id @default(cuid())
  token        String    @unique
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  praxisUserId String?
  praxisUser   PraxisUser? @relation(fields: [praxisUserId], references: [id], onDelete: Cascade)
  email        String
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime  @default(now())

  @@index([token])
  @@index([projectId])
}

model ContentApproval {
  id            String      @id @default(cuid())
  projectId     String
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contentIndex  Int
  status        String      @default("ausstehend")
  approvedAt    DateTime?
  approvedById  String?
  approvedBy    PraxisUser? @relation(fields: [approvedById], references: [id])
  createdAt     DateTime    @default(now())

  @@unique([projectId, contentIndex])
  @@index([projectId, status])
}

model Comment {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contentIndex Int
  text         String
  authorName   String
  authorRole   String   @default("praxis")
  createdAt    DateTime @default(now())

  @@index([projectId, contentIndex])
}

model CostReport {
  id        String   @id @default(cuid())
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  month     String
  totalEur  Float
  breakdown Json
  pdfPath   String?
  createdAt DateTime @default(now())

  @@index([month])
  @@index([projectId])
}

model MonthlyReport {
  id          String    @id @default(cuid())
  period      String    @unique  // Format: "2026-05" (JJJJ-MM)
  pdfPath     String
  generatedAt DateTime  @default(now())
  sentAt      DateTime?
}

model AuditLog {
  id         String   @id @default(cuid())
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId     String?
  userEmail  String?
  action     String
  entity     String
  entityId   String?
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([projectId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

enum Role {
  ADMIN
  STAFF
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ReviewMode {
  SIMPLE
  COMPLETE
}

enum GenerationJobStatus {
  PENDING
  QUEUED
  RUNNING
  COMPLETE
  ERROR
}

enum Provider {
  ANTHROPIC
  OPENAI
  DATASEO
  KLICKTIPP
  WORDPRESS
  HEDY
  CANVA
  META
  LINKEDIN
}
