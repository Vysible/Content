generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma/client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(STAFF)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiKeys  ApiKey[]
  projects Project[]
}

model ApiKey {
  id           String    @id @default(cuid())
  name         String
  provider     Provider
  encryptedKey String
  model        String?
  active       Boolean   @default(true)
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  @@index([provider, active])
}

model Project {
  id                  String        @id @default(cuid())
  name                String
  praxisUrl           String
  praxisName          String?
  fachgebiet          String?
  planningStart       DateTime
  planningEnd         DateTime
  channels            String[]
  positioningDocument String?
  themenPool          String?
  keywords            String[]
  canvaFolderId       String?
  wpUrl               String?
  ktListId            String?
  scrapedData         Json?
  themeResults        Json?
  textResults         Json?
  status              ProjectStatus @default(DRAFT)
  shareLinks          ShareLink[]
  praxisUsers         PraxisUser[]
  comments            Comment[]
  costReports         CostReport[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  createdById String
  createdBy   User        @relation(fields: [createdById], references: [id])
  costEntries CostEntry[]

  @@index([status])
  @@index([createdById])
}

model CostEntry {
  id           String   @id @default(cuid())
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  timestamp    DateTime @default(now())
  model        String
  inputTokens  Int
  outputTokens Int
  costEur      Float
  step         String

  @@index([projectId])
  @@index([timestamp])
}

model ShareLink {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  token        String   @unique @default(cuid())
  passwordHash String
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([token])
  @@index([projectId])
}

model PraxisUser {
  id            String    @id @default(cuid())
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  email         String
  name          String
  inviteToken   String    @unique @default(cuid())
  inviteExpires DateTime
  active        Boolean   @default(false)
  createdAt     DateTime  @default(now())

  @@index([inviteToken])
  @@index([projectId])
}

model Comment {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contentIndex Int
  text         String
  authorName   String
  authorRole   String   @default("praxis")
  createdAt    DateTime @default(now())

  @@index([projectId, contentIndex])
}

model CostReport {
  id        String   @id @default(cuid())
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  month     String
  totalEur  Float
  breakdown Json
  pdfPath   String?
  createdAt DateTime @default(now())

  @@index([month])
  @@index([projectId])
}

enum Role {
  ADMIN
  STAFF
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum Provider {
  ANTHROPIC
  OPENAI
  DATASEO
  KLICKTIPP
  WORDPRESS
  HEDY
  CANVA
}
