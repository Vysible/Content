# Datenbank (PostgreSQL)
# Dev via docker-compose: postgresql://vysible:vysible@localhost:5432/vysible
# Prod via Coolify: wird automatisch gesetzt
# connection_limit=10 empfohlen für Prod (VPS mit 10+ aktiven Projekten)
# pool_timeout=30 verhindert hängende Requests bei Lastspitzen
DATABASE_URL="postgresql://vysible:vysible@localhost:5432/vysible?connection_limit=10&pool_timeout=30"

# Auth.js v5 – zufälliger 32+ Zeichen String
# Generieren: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_RANDOM_SECRET"
NEXTAUTH_URL="http://localhost:3000"

# AES-256-GCM Schlüssel (Version 1) — 64 Hex-Zeichen = 32 Bytes
# Generieren: openssl rand -hex 32
# Bei bestehenden Instanzen: gleicher Wert wie bisheriger ENCRYPTION_SECRET
ENCRYPTION_SECRET_V1="REPLACE_WITH_64_CHAR_HEX_STRING"
# Legacy-Fallback (nach migrate-aes-prefix.ts --apply auf Prod entfernen)
# ENCRYPTION_SECRET="REPLACE_WITH_64_CHAR_HEX_STRING"

# Einmaliges Setup-Passwort für /api/setup (Admin-Erstanlage)
# Nach erstem Login sofort in den Einstellungen ändern und diese Variable entfernen.
INITIAL_ADMIN_PASSWORD="CHANGE_ME_BEFORE_FIRST_START"

# App-URL (Prod: https://vysible.cloud)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Canva OAuth 2.0 (Sprint P2-E, Slice 17)
# Canva Developer Portal: https://www.canva.com/developers/
# -> Neue App anlegen (OAuth 2.0), dann Client-ID und Secret kopieren.
# Redirect-URIs in der Canva-App registrieren:
#   Dev:  http://localhost:3000/api/canva/oauth/callback
#   Prod: https://vysible.cloud/api/canva/oauth/callback
CANVA_CLIENT_ID="REPLACE_WITH_CANVA_CLIENT_ID"
CANVA_CLIENT_SECRET="REPLACE_WITH_CANVA_CLIENT_SECRET"

# Playwright-Scraper-Service (intern, kein externer Zugriff)
# Dev via docker-compose: http://playwright:3001
# Prod via Coolify: http://playwright:3001
PLAYWRIGHT_SERVICE_URL="http://playwright:3001"

# ──────────────────────────────────────────────────────────────
# Hedy (Positionierungs-Interview, Slice 20)
# ──────────────────────────────────────────────────────────────
# Der Hedy API-Key wird NICHT hier abgelegt, sondern AES-256-verschlüsselt
# in der DB gespeichert (Einstellungen → API-Keys → Provider "HEDY").
# Auth-Schema: Bearer-Token gegen https://api.hedy.bot/mcp
#
# Optional: Base-URL überschreiben (z.B. für lokalen Mock-Server)
# HEDY_BASE_URL="https://api.hedy.bot/mcp"

# ──────────────────────────────────────────────────────────────
# KlickTipp (Newsletter-Connector, Slice 23)
# ──────────────────────────────────────────────────────────────
# KlickTipp-Credentials werden NICHT hier abgelegt, sondern AES-256-
# verschlüsselt in der DB (Einstellungen → API-Keys → Provider "KLICKTIPP").
# Format in DB: Name = "kt:<benutzername>", encryptedKey = <passwort>
# Auth-Schema: Session-basiert (POST /account/login → sessid)
#
# Optional: Standard-Listen-ID (kann auch pro Projekt in der UI gesetzt werden)
# KLICKTIPP_DEFAULT_LIST_ID=""

# ──────────────────────────────────────────────────────────────
# Praxis-Portal Session (signierter httpOnly-Cookie, Drift-Fix P3-C)
# ──────────────────────────────────────────────────────────────
# Generieren: openssl rand -base64 32
PRAXIS_SESSION_SECRET="REPLACE_WITH_RANDOM_SECRET_MIN_32_CHARS"

# ──────────────────────────────────────────────────────────────
# Unsplash API (Bildbriefing erweitert, Slice 15)
# ──────────────────────────────────────────────────────────────
# Unsplash Developer Portal: https://unsplash.com/developers
# -> Neue App anlegen -> Access Key kopieren
# Demo-Key-Limit: 50 Requests/h | Production: 1.000 Requests/h
# Optional: Ohne Key werden keine Unsplash-Links generiert (graceful degradation)
# UNSPLASH_ACCESS_KEY="REPLACE_WITH_UNSPLASH_ACCESS_KEY"

# ──────────────────────────────────────────────────────────────
# Themen-Quality-Gate (optional, Defaults aus plan.md Spec)
# ──────────────────────────────────────────────────────────────
# THEMES_MIN_PRAXIS_QUOTE=0.8
# THEMES_MIN_SEO_QUOTE=0.5

# ──────────────────────────────────────────────────────────────
# Audit-Log-Retention (Standard: 30 Tage)
# ──────────────────────────────────────────────────────────────
# AUDIT_LOG_RETENTION_DAYS=30
